---

<BaseLayout title={`${personal.name} — Software Engineer`}>
  <Hero
    name={personal.name}
    title={personal.title}
    tagline={personal.tagline}
    githubUrl={personal.githubUrl}
    linkedinUrl={personal.linkedinUrl}
    profileImage={personal.profileImage}
  />

  <div class="divider"><div class="container"></div></div>

  <About bio={bio} skills={skills} />

  <div class="divider"><div class="container"></div></div>

  <Experience items={experience} />

  <div class="divider"><div class="container"></div></div>

  <Testimonials items={testimonials} />

  <div class="divider"><div class="container"></div></div>

  <Contact
    email={personal.email}
    githubUrl={personal.githubUrl}
    linkedinUrl={personal.linkedinUrl}
  />
</BaseLayout>

<style>
  .divider {
    width: 100%;
    height: 1px;
    background: var(--border);
  }
</style>
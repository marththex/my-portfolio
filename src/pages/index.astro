---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import type { ExperienceItem } from '../components/Experience.astro';
import Testimonials from '../components/Testimonials.astro';
import { testimonials } from '../data/testimonials';
import Contact from '../components/Contact.astro';

// ─── YOUR DATA — edit everything below ───────────────────────────────────────

const personal = {
  name: "Marcus Chong",
  title: "Software Engineer — Artificial Intelligence",
  tagline: "I build computer vision systems, ML infrastructure, and full-stack AI applications — turning research into reliable, production-grade software.",
  email: "marcuslchong@gmail.com",
  githubUrl: "https://github.com/marththex",
  linkedinUrl: "https://linkedin.com/in/marcuslchong",
  // Replace with your actual image path in /public — e.g. /profile.jpg
  profileImage: "/profile.jpg",
};

const bio: string[] = [
  "I'm a software engineer specialising in artificial intelligence and computer vision, based in Long Beach, California. Over the past 7+ years I've worked across the full stack — from low-level network systems to production ML pipelines — with a focus on shipping AI that actually works in the real world.",
  "At Boeing, I've developed computer vision tooling with 98% detection accuracy, architected enterprise ML infrastructure, and co-authored internal research that was presented at the Boeing Internal Conference. I care about the unglamorous details: robust pipelines, thorough testing, and documentation that teams can actually rely on.",
  "Outside of work I run a home lab, contribute to open source, and stay sharp on the latest in systems design and applied ML. If it involves building something with real constraints and real stakes, I'm interested.",
];

const skills: string[] = [
  "Python",
  "AI & ML",
  "React & Full-Stack Dev",
  "REST APIs, Data & RAG Pipelines",
  "Docker, Kubernetes, & CI/CD",
  "PostgresSQL, MongoDB & AWS S3",
  "UDP/IP & TCP/IP",
];

const experience: ExperienceItem[] = [
  {
    company: "Boeing",
    role: "Software Engineer — Artificial Intelligence",
    period: "Mar 2022 — Present",
    location: "Long Beach, CA",
    description: "Building AI and computer vision systems for automated parts inspection, ML infrastructure, and full-stack data pipelines. Working at the intersection of applied research and production engineering.",
    highlights: [
      "Developed computer vision tool for automated parts detection achieving 98% accuracy with 0.5–3s processing times",
      "Reduced inspection reporting time by 67% through AI-powered automation",
      "Co-authored Boeing Internal Research paper; presented at Boeing Internal Conference (2025) with 4 abstracts approved for 2026",
      "Built RAG-powered chatbot enabling visual part inspection via vector database queries for defect detection and documentation retrieval",
      "Developed full-stack React data acquisition app with a pipeline covering frame extraction, audio separation, Faster Whisper speech-to-text, OCR, and YOLOv8 object detection — metadata in MongoDB, objects in AWS S3",
      "Architected enterprise ML infrastructure using Voxel51, accelerating team AI/CV workflows",
      "Created middleware policy decision point (PDP) managing US Export access controls across international boundaries",
      "Managed multiple team servers with full-stack deployments; configured Nginx reverse proxy, routing, and database architecture",
    ],
    tech: ["Python", "YOLOv8", "React", "RAG", "Voxel51", "Docker", "MongoDB", "AWS S3", "Nginx", "CI/CD", "REST APIs"],
  },
  {
    company: "Boeing",
    role: "Software Engineer — Network & Cyber Systems",
    period: "Jan 2019 — Feb 2022",
    location: "Huntington Beach, CA",
    description: "Focused on network systems engineering — designing messaging frameworks, simulation environments, and performance optimisation across complex network topologies.",
    highlights: [
      "Deployed unified messaging framework combining UDP speed with TCP reliability",
      "Architected network simulation capabilities for testing software across diverse topologies",
      "Analysed network performance bottlenecks and optimised message delivery systems",
    ],
    tech: ["TCP/IP", "UDP/IP", "ActiveMQ", "Network Simulation", "C++"],
  },
];

---

<BaseLayout title={`${personal.name} — Software Engineer`}>
  <Hero
    name={personal.name}
    title={personal.title}
    tagline={personal.tagline}
    githubUrl={personal.githubUrl}
    linkedinUrl={personal.linkedinUrl}
    profileImage={personal.profileImage}
  />

  <div class="divider"><div class="container"></div></div>

  <About bio={bio} skills={skills} />

  <div class="divider"><div class="container"></div></div>

  <Experience items={experience} />

  <div class="divider"><div class="container"></div></div>

  <Testimonials items={testimonials} />

  <div class="divider"><div class="container"></div></div>

  <Contact
    email={personal.email}
    githubUrl={personal.githubUrl}
    linkedinUrl={personal.linkedinUrl}
  />
</BaseLayout>

<style>
  .divider {
    width: 100%;
    height: 1px;
    background: var(--border);
  }
</style>
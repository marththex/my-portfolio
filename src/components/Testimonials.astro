---
import type { Testimonial } from '../data/testimonials';

interface Props {
  items: Testimonial[];
}

const { items } = Astro.props;
---

<section class="section" id="testimonials" aria-labelledby="testimonials-heading">
  <div class="container">
    <p class="section-label">Kind words</p>
    <h2 class="section-title testimonials-title" id="testimonials-heading">What colleagues say</h2>

    <div
      class="carousel-viewport"
      id="carouselViewport"
      tabindex="0"
      role="group"
      aria-roledescription="carousel"
      aria-label="Colleague testimonials"
    >
      <div class="carousel-track" id="carouselTrack">
        {items.map((item) => (
          <article class="carousel-card">
            <div class="card-quote-mark" aria-hidden="true">&ldquo;</div>
            <p class="card-quote">{item.quote}</p>
            <div class="card-author">
              <div class="author-avatar" aria-hidden="true">{item.initials}</div>
              <div class="author-info">
                <p class="author-name">{item.name}</p>
                <p class="author-role">{item.role}</p>
                <p class="author-company">{item.company}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="carousel-controls">
      <button class="carousel-btn" id="prevBtn" aria-label="Previous testimonials">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
      </button>
      <div class="carousel-progress" aria-hidden="true">
        <div class="carousel-thumb" id="carouselThumb"></div>
      </div>
      <button class="carousel-btn" id="nextBtn" aria-label="Next testimonials">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .testimonials-title {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
  }

  /* Native horizontal scroll with snap — aligned to the page container,
     no clones, no transform math. */
  .carousel-viewport {
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding: 1rem 0 2rem;
    overscroll-behavior-x: contain;
  }

  .carousel-viewport::-webkit-scrollbar { display: none; }

  .carousel-viewport:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 4px;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
  }

  .carousel-card {
    flex: 0 0 calc((100% - 3rem) / 3);
    scroll-snap-align: start;
    min-width: 0;
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s;
  }

  .carousel-card:hover { border-color: var(--accent); }

  .card-quote-mark {
    font-family: var(--font-body);
    font-size: 4rem;
    line-height: 0.5;
    color: var(--accent);
    opacity: 0.4;
    margin-bottom: 1rem;
    font-style: italic;
    flex-shrink: 0;
  }

  .card-quote {
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.75;
    font-style: italic;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .card-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--accent);
    flex-shrink: 0;
  }

  .author-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text);
  }

  .author-role {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-3);
    margin-top: 0.15rem;
    line-height: 1.4;
  }

  .author-company {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--accent);
    opacity: 0.7;
    margin-top: 0.1rem;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .carousel-btn {
    width: 44px;
    height: 44px;
    border: 1px solid var(--border);
    background: var(--bg-2);
    color: var(--text-2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  .carousel-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-3);
  }

  /* Scrollbar-style progress line between the buttons */
  .carousel-progress {
    position: relative;
    flex: 1;
    height: 2px;
    background: var(--border);
  }

  .carousel-thumb {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--accent);
    transition: left 0.15s linear, width 0.15s linear;
  }

  /* Tablet: 2 cards */
  @media (max-width: 900px) {
    .carousel-card {
      flex-basis: calc((100% - 1.5rem) / 2);
    }
  }

  /* Mobile: 1 card */
  @media (max-width: 580px) {
    .carousel-card {
      flex-basis: 100%;
    }
  }
</style>

<script>
  const viewport = document.getElementById('carouselViewport') as HTMLElement;
  const track    = document.getElementById('carouselTrack')    as HTMLElement;
  const prevBtn  = document.getElementById('prevBtn')          as HTMLButtonElement;
  const nextBtn  = document.getElementById('nextBtn')          as HTMLButtonElement;
  const thumb    = document.getElementById('carouselThumb')    as HTMLElement;

  const GAP = 24; // matches the 1.5rem track gap
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

  const step = () => (track.children[0] as HTMLElement).offsetWidth + GAP;
  const maxScroll = () => viewport.scrollWidth - viewport.clientWidth;

  function scrollToX(x: number): void {
    viewport.scrollTo({ left: x, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
  }

  // Buttons wrap around at the ends
  function next(): void {
    const max = maxScroll();
    scrollToX(viewport.scrollLeft >= max - 1 ? 0 : Math.min(viewport.scrollLeft + step(), max));
  }

  function prev(): void {
    scrollToX(viewport.scrollLeft <= 1 ? maxScroll() : Math.max(viewport.scrollLeft - step(), 0));
  }

  prevBtn.addEventListener('click', prev);
  nextBtn.addEventListener('click', next);

  viewport.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'ArrowLeft')  { e.preventDefault(); prev(); }
    if (e.key === 'ArrowRight') { e.preventDefault(); next(); }
  });

  // Progress thumb mirrors the scroll position, like a minimal scrollbar
  function updateThumb(): void {
    const total = viewport.scrollWidth;
    const max = maxScroll();
    const width = (viewport.clientWidth / total) * 100;
    const left = max > 0 ? (viewport.scrollLeft / max) * (100 - width) : 0;
    thumb.style.width = `${width}%`;
    thumb.style.left = `${left}%`;
  }

  let ticking = false;
  viewport.addEventListener('scroll', () => {
    if (ticking) return;
    ticking = true;
    requestAnimationFrame(() => {
      updateThumb();
      ticking = false;
    });
  });

  window.addEventListener('resize', updateThumb);
  updateThumb();
</script>

---
export interface Testimonial {
  quote: string;
  name: string;
  role: string;
  company: string;
  initials: string;
}

interface Props {
  items: Testimonial[];
}

const { items } = Astro.props;
---

<section class="section" id="testimonials">
  <div class="container">
    <p class="section-label">Testimonials</p>
    <h2 class="section-title testimonials-title">What colleagues say</h2>
  </div>

  <!-- Viewport sits OUTSIDE container so cards can bleed edge-to-edge -->
  <div class="carousel-viewport" id="carouselViewport">
    <div class="carousel-track" id="carouselTrack">
      {items.map((item) => (
        <div class="carousel-card">
          <div class="card-quote-mark">"</div>
          <p class="card-quote">{item.quote}</p>
          <div class="card-author">
            <div class="author-avatar">{item.initials}</div>
            <div class="author-info">
              <p class="author-name">{item.name}</p>
              <p class="author-role">{item.role} · {item.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="container">
    <div class="carousel-controls">
      <button class="carousel-btn" id="prevBtn" aria-label="Previous">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 5l-7 7 7 7"/>
        </svg>
      </button>
      <div class="carousel-dots" id="carouselDots">
        {items.map((_, i) => (
          <button class={`dot ${i === 0 ? 'active' : ''}`} data-i={i} aria-label={`Go to ${i + 1}`}></button>
        ))}
      </div>
      <button class="carousel-btn" id="nextBtn" aria-label="Next">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .testimonials-title {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
  }

  .carousel-viewport {
    overflow: hidden;
    padding: 1rem 0 2rem;
    touch-action: pan-y;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    cursor: grab;
    user-select: none;
    touch-action: pan-y;
    /* Left padding aligns first card with page container */
    padding-left: max(1.25rem, calc((100vw - min(100vw, 1100px)) / 2 + 2rem));
  }

  .carousel-track.dragging {
    cursor: grabbing;
    transition: none;
  }

  /* Card widths are all viewport-relative so % of track doesn't confuse things */
  .carousel-card {
    flex: 0 0 calc((min(100vw, 1100px) - 4rem - 3rem) / 3);
    min-width: 0;
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s;
    content-visibility: visible;
    contain: none;
  }

  .carousel-card:hover { border-color: var(--accent); }

  .card-quote-mark {
    font-family: var(--font-body);
    font-size: 4rem;
    line-height: 0.5;
    color: var(--accent);
    opacity: 0.4;
    margin-bottom: 1rem;
    font-style: italic;
    flex-shrink: 0;
  }

  .card-quote {
    color: var(--text);
    font-size: 0.95rem;
    line-height: 1.75;
    font-style: italic;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .card-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    flex-shrink: 0;
  }

  .author-avatar {
    width: 40px;
    height: 40px;
    background: var(--bg-3);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.8rem;
    color: var(--accent);
    flex-shrink: 0;
  }

  .author-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--text);
  }

  .author-role {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-3);
    margin-top: 0.15rem;
  }

  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .carousel-btn {
    width: 44px;
    height: 44px;
    border: 1px solid var(--border);
    background: var(--bg-2);
    color: var(--text-2);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    flex-shrink: 0;
  }

  .carousel-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--bg-3);
  }

  .carousel-dots {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border);
    border: none;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    padding: 0;
    flex-shrink: 0;
  }

  .dot.active {
    background: var(--accent);
    transform: scale(1.4);
  }

  /* Tablet: 2 cards */
  @media (max-width: 900px) {
    .carousel-card {
      flex: 0 0 calc((100vw - 2.5rem - 1.5rem) / 2);
    }
  }

  /* Mobile: 1 card, centered with equal padding on both sides */
  @media (max-width: 580px) {
    .carousel-viewport {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
    .carousel-track {
      padding-left: 0;
    }
    .carousel-card {
      flex: 0 0 calc(100vw - 2.5rem);
    }
  }
</style>

<script>
  const viewport  = document.getElementById('carouselViewport') as HTMLElement;
  const track     = document.getElementById('carouselTrack')    as HTMLElement;
  const prevBtn   = document.getElementById('prevBtn')          as HTMLButtonElement;
  const nextBtn   = document.getElementById('nextBtn')          as HTMLButtonElement;
  const dots      = Array.from(document.querySelectorAll<HTMLButtonElement>('.dot'));
  const origCards = Array.from(track.querySelectorAll<HTMLElement>('.carousel-card'));
  const total     = origCards.length;
  const CLONES    = 3;

  // ── Clone for infinite loop ──────────────────────────────────────────────────
  for (let i = CLONES - 1; i >= 0; i--) {
    const clone = origCards[total - CLONES + i].cloneNode(true) as HTMLElement;
    clone.setAttribute('aria-hidden', 'true');
    track.insertBefore(clone, track.firstChild);
  }
  for (let i = 0; i < CLONES; i++) {
    const clone = origCards[i].cloneNode(true) as HTMLElement;
    clone.setAttribute('aria-hidden', 'true');
    track.appendChild(clone);
  }

  let current      = CLONES;
  let logicalIndex = 0;

  // ── Card width — read from DOM so it matches CSS exactly ────────────────────
  function getCardWidth(): number {
    const c = track.children[0] as HTMLElement;
    // offsetWidth + gap (1.5rem = 24px)
    return c.offsetWidth + 24;
  }

  function setTranslate(x: number, animated: boolean): void {
    track.style.transition = animated
      ? 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)'
      : 'none';
    track.style.transform = `translateX(-${x}px)`;
  }

  function updateDots(logical: number): void {
    const w = ((logical % total) + total) % total;
    dots.forEach((d, i) => d.classList.toggle('active', i === w));
  }

  // Init
  setTranslate(getCardWidth() * current, false);
  updateDots(logicalIndex);

  // ── Infinite warp ────────────────────────────────────────────────────────────
  track.addEventListener('transitionend', () => {
    if (current >= total + CLONES) {
      current -= total;
      setTranslate(getCardWidth() * current, false);
    } else if (current < CLONES) {
      current += total;
      setTranslate(getCardWidth() * current, false);
    }
  });

  // ── Navigate ─────────────────────────────────────────────────────────────────
  function goTo(domIndex: number): void {
    current      = domIndex;
    logicalIndex = ((domIndex - CLONES) % total + total) % total;
    setTranslate(getCardWidth() * current, true);
    updateDots(logicalIndex);
  }

  const next = () => goTo(current + 1);
  const prev = () => goTo(current - 1);

  prevBtn.addEventListener('click', prev);
  nextBtn.addEventListener('click', next);
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i + CLONES)));

  // ── Drag / swipe ─────────────────────────────────────────────────────────────
  let dragStartX      = 0;
  let dragStartOffset = 0;
  let isDragging      = false;
  let touchStartY     = 0;
  let isHorizontal    = false;

  function onDragStart(x: number, y = 0): void {
    isDragging      = true;
    isHorizontal    = false;
    dragStartX      = x;
    touchStartY     = y;
    dragStartOffset = getCardWidth() * current;
    track.classList.add('dragging');
  }

  function onDragMove(x: number, y = 0): void {
    if (!isDragging) return;
    const dx = Math.abs(x - dragStartX);
    const dy = Math.abs(y - touchStartY);
    if (!isHorizontal && (dx > 5 || dy > 5)) {
      isHorizontal = dx >= dy;
    }
    if (isHorizontal) {
      setTranslate(dragStartOffset + (dragStartX - x), false);
    }
  }

  function onDragEnd(x: number): void {
    if (!isDragging) return;
    isDragging = false;
    track.classList.remove('dragging');
    if (isHorizontal) {
      const delta = dragStartX - x;
      Math.abs(delta) > 60 ? (delta > 0 ? next() : prev()) : setTranslate(getCardWidth() * current, true);
    }
  }

  // Touch
  track.addEventListener('touchstart',  (e: TouchEvent) => onDragStart(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
  track.addEventListener('touchmove',   (e: TouchEvent) => {
    const dx = Math.abs(e.touches[0].clientX - dragStartX);
    const dy = Math.abs(e.touches[0].clientY - touchStartY);
    if (!isHorizontal && (dx > 5 || dy > 5)) isHorizontal = dx >= dy;
    if (isHorizontal) {
      e.preventDefault();
      onDragMove(e.touches[0].clientX, e.touches[0].clientY);
    }
  }, { passive: false });
  track.addEventListener('touchend',    (e: TouchEvent) => onDragEnd(e.changedTouches[0].clientX));

  // Mouse
  track.addEventListener('mousedown',  (e: MouseEvent) => onDragStart(e.clientX));
  window.addEventListener('mousemove', (e: MouseEvent) => onDragMove(e.clientX));
  window.addEventListener('mouseup',   (e: MouseEvent) => onDragEnd(e.clientX));

  // Resize
  window.addEventListener('resize', () => setTranslate(getCardWidth() * current, false));
</script>
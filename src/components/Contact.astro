---
interface Props {
  githubUrl: string;
  linkedinUrl: string;
}

const { githubUrl, linkedinUrl } = Astro.props;
---

<section class="section" id="contact">
  <div class="container">
    <p class="section-label">Contact</p>
    <div class="contact-grid">
      <div class="contact-left">
        <h2 class="section-title">Let's work<br/><em>together</em></h2>
        <p class="contact-sub">
          Have a project in mind, a role to fill, or just want to connect?
          Drop me a message and I'll get back to you within 24 hours.
        </p>
        <div class="contact-links">
          <a href={githubUrl} target="_blank" rel="noopener" class="contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <a href={linkedinUrl} target="_blank" rel="noopener" class="contact-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>

      <form class="contact-form" id="contactForm" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="name" class="form-label">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              placeholder="Jane Smith"
              required
            />
            <span class="form-error" id="nameError"></span>
          </div>
          <div class="form-group">
            <label for="email" class="form-label">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="jane@example.com"
              required
            />
            <span class="form-error" id="emailError"></span>
          </div>
        </div>
        <div class="form-group">
          <label for="subject" class="form-label">Subject</label>
          <input
            type="text"
            id="subject"
            name="subject"
            class="form-input"
            placeholder="Project inquiry / Collaboration / Just saying hi"
          />
        </div>
        <div class="form-group">
          <label for="message" class="form-label">Message</label>
          <textarea
            id="message"
            name="message"
            class="form-input form-textarea"
            placeholder="Tell me about what you're working on..."
            rows={6}
            required
          ></textarea>
          <span class="form-error" id="messageError"></span>
        </div>
        <button type="submit" class="form-submit" id="submitBtn">
          <span class="submit-text">Send message</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/>
          </svg>
        </button>
        <div class="form-success" id="formSuccess">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          Message received! I'll be in touch soon.
        </div>
        <div class="form-error-msg" id="formErrorMsg"></div>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-left h2 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .contact-left h2 em {
    font-style: italic;
    color: var(--accent);
  }

  .contact-sub {
    color: var(--text-2);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    font-size: 1.05rem;
  }

  .contact-email {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    margin-bottom: 1.5rem;
    transition: opacity 0.2s;
  }

  .contact-email:hover { opacity: 0.7; }

  .contact-links {
    display: flex;
    gap: 1.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-2);
    transition: color 0.2s;
  }

  .contact-link:hover { color: var(--accent); }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-3);
  }

  .form-input {
    background: var(--bg-2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 0.85rem 1rem;
    font-family: var(--font-body);
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
    resize: none;
  }

  .form-input::placeholder { color: var(--text-3); }

  .form-input:focus {
    border-color: var(--accent);
  }

  .form-input.error {
    border-color: #ff4444;
  }

  .form-error {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #ff4444;
    min-height: 1em;
  }

  .form-textarea {
    min-height: 160px;
    line-height: 1.6;
  }

  .form-submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 1rem 2rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    letter-spacing: 0.02em;
  }

  .form-submit:hover { opacity: 0.88; transform: translateY(-2px); }
  .form-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .form-note {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-3);
    line-height: 1.5;
  }

  .form-success {
    display: none;
    align-items: center;
    gap: 0.75rem;
    background: rgba(232, 255, 71, 0.1);
    border: 1px solid var(--accent);
    padding: 1rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
  }

  .form-success.visible { display: flex; }

  .form-error-msg {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #ff4444;
    min-height: 1em;
  }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const successMsg = document.getElementById('formSuccess') as HTMLElement;
  const errorMsg = document.getElementById('formErrorMsg') as HTMLElement;

  type FieldId = 'name' | 'email' | 'message';

  function validateField(id: FieldId): boolean {
    const input = document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
    const error = document.getElementById(`${id}Error`) as HTMLSpanElement;
    let msg = '';

    if (id === 'name' && !input.value.trim()) {
      msg = 'Name is required.';
    } else if (id === 'email') {
      if (!input.value.trim()) {
        msg = 'Email is required.';
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value)) {
        msg = 'Please enter a valid email.';
      }
    } else if (id === 'message' && input.value.trim().length < 10) {
      msg = 'Message must be at least 10 characters.';
    }

    error.textContent = msg;
    input.classList.toggle('error', !!msg);
    return !msg;
  }

  (['name', 'email', 'message'] as FieldId[]).forEach(id => {
    const input = document.getElementById(id);
    input?.addEventListener('blur', () => validateField(id));
    input?.addEventListener('input', () => validateField(id));
  });

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();

    const validName    = validateField('name');
    const validEmail   = validateField('email');
    const validMessage = validateField('message');

    if (!validName || !validEmail || !validMessage) return;

    submitBtn.disabled = true;
    errorMsg.textContent = '';
    (submitBtn.querySelector('.submit-text') as HTMLElement).textContent = 'Sending…';

    try {
      const formData = new FormData(form);
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: formData,
      });

      const data = await res.json();

      if (res.ok && data.success) {
        form.reset();
        successMsg.classList.add('visible');
        setTimeout(() => successMsg.classList.remove('visible'), 6000);
      } else {
        errorMsg.textContent = 'Something went wrong. Please try again.';
      }
    } catch {
      errorMsg.textContent = 'Network error. Please check your connection and try again.';
    } finally {
      submitBtn.disabled = false;
      (submitBtn.querySelector('.submit-text') as HTMLElement).textContent = 'Send message';
    }
  });
</script>
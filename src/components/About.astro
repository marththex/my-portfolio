---
export interface SkillGroup {
  label: string;
  items: string[];
}

interface Props {
  bio: string[];
  skills: SkillGroup[];
}

const { bio, skills } = Astro.props;
---

<section class="section" id="about">
  <div class="container">
    <p class="section-label">About</p>
    <div class="about-grid">
      <div class="about-text">
        <h2 class="section-title">AI that holds up<br/><em>in production</em></h2>
        {bio.map((paragraph) => (
          <p class="about-para">{paragraph}</p>
        ))}
      </div>
      <div class="about-skills">
        <p class="skills-label">Tech I work with</p>
        <div class="skills-groups">
          {skills.map((group) => (
            <div class="skill-group">
              <p class="skill-group-label">{group.label}</p>
              <ul class="skill-chips">
                {group.items.map((item) => (
                  <li class="skill-chip">{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 5rem;
    align-items: start;
  }

  .about-text h2 em {
    font-style: italic;
    color: var(--accent);
  }

  .about-para {
    color: var(--text-2);
    margin-bottom: 1.25rem;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .about-skills {
    background: var(--bg-2);
    border: 1px solid var(--border);
    padding: 2rem;
    position: sticky;
    top: 6rem;
  }

  .skills-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-3);
    margin-bottom: 1.5rem;
  }

  .skills-groups {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-group:not(:last-child) {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-group-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .skill-chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-chip {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    padding: 0.25rem 0.6rem;
    background: var(--bg-3);
    border: 1px solid var(--border);
    color: var(--text-2);
    letter-spacing: 0.03em;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .about-skills { position: static; }
  }
</style>